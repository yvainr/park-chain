{
  "name": "park-chain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build:contracts": "hardhat compile --config hardhat.config.cjs",
    "test:contracts": "hardhat test --config hardhat.config.cjs",
    "node:contracts": "hardhat node --config hardhat.config.cjs",
    "deploy:contracts:local": "hardhat run scripts/deploy-hardhat.ts --network localhost",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-network-helpers": "^3.0.0",
    "@nomicfoundation/hardhat-node-test-runner": "^3.0.0",
    "@nomicfoundation/hardhat-viem": "^3.0.0",
    "@nomicfoundation/hardhat-viem-assertions": "^3.0.0",
    "@openzeppelin/contracts": "^5.6.1",
    "hardhat": "^3.0.0",
    "typescript": "^5.8.0",
    "viem": "^2.30.0"
  }
}
